{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "shanghai-gov-proxy",
  "compatibility_date": "2026-04-12",
  "compatibility_flags": ["nodejs_compat"],
  "main": "index.ts",
  "routes": [
    {
      "pattern": "proxy.autoyj.com",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "joyspace-work-db",
      "database_id": "30e652e7-5050-4d97-88d0-f32b5e109e55"
    }
  ]
}
